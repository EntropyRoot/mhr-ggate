[Unit]
Description=mhr-ggate VPS relay
After=network.target xray.service
Wants=xray.service

[Service]
Type=simple
EnvironmentFile=-/etc/mhr-ggate/relay.env
WorkingDirectory=/opt/mhr-ggate
ExecStart=/opt/mhr-ggate/.venv/bin/python /opt/mhr-ggate/server/server.py
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log

[Install]
WantedBy=multi-user.target
